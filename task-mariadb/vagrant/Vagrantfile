Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-24.04"

  config.vm.provider "virtualbox" do |vb|
    vb.memory = "1024"
    vb.cpus = 1
  end
  
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # Istanza di origine su cui viene eseguito il backup del database.
  config.vm.define "db-source-01" do |source|
    source.vm.hostname = "db-source-01"
    source.vm.network "private_network", ip: "192.168.56.2"
  end

  # Istanza di destinazione vuota che riceve il restore.
  config.vm.define "db-target-01" do |target|
    target.vm.hostname = "db-target-01"
    target.vm.network "private_network", ip: "192.168.56.3"
  end
end